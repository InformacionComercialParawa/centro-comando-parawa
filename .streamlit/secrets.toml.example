[gemini]
api_key = "TU_API_KEY_AQUI"

[data]
parquet_folder   = "RUTA_A_FUENTES_BRUTAS"
maestros_folder  = "RUTA_A_MAESTROS"
procesada_folder = "RUTA_A_PROCESADA"
exports_folder   = "RUTA_A_EXPORTS"

[drive]
folder_id = "ID_DE_TU_CARPETA_PARAWA_APP_DATA"

[passwords]
admin            = "CAMBIAR_EN_PRODUCCION"
# Usuarios reales — agregar según estructura del proyecto
# gerente_capital  = "..."
# asesor_caracas1  = "..."

# ── USUARIOS DEMO (para presentaciones) ─────────────────────────────────────
demo_admin       = "Demo2026"
demo_gerente_cap = "Demo2026"
demo_gerente_ori = "Demo2026"
demo_asesor_1    = "Demo2026"

[access.admin]
region = "TODOS"

# ── ACCESOS DEMO ─────────────────────────────────────────────────────────────

[access.demo_admin]
region = "TODOS"

[access.demo_gerente_cap]
region = "Capital"

[access.demo_gerente_ori]
region = "Oriente"

[access.demo_asesor_1]
distribuidores = ["CARACAS - DISTRIBUIDORA DEMO 1, C.A"]

# ── CONFIGURACION DE MODO ────────────────────────────────────────────────────
# Controla qué archivo Parquet carga la app al iniciar:
#   "produccion"  → lee sellout_consolidado.parquet  (datos reales desde Drive o disco)
#   "demo"        → lee sellout_demo_consolidado.parquet (datos ficticios para demos)
#                   Muestra un banner amarillo de advertencia visible en toda la sesión.
# Cambiar este valor en secrets.toml para alternar entre modos sin tocar el código.

[app]
modo = "demo"
